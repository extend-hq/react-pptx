{
  "name": "@extend-ai/react-pptx",
  "version": "0.1.0",
  "description": "Browser-native, virtualized React viewer for PowerPoint PPT and PPTX files",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pptx_wasm_bg.wasm": "./dist/pptx_wasm_bg.wasm",
    "./styles.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "THIRD_PARTY_NOTICES.md",
    "THIRD_PARTY_LICENSES"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/react-viewer/src"
  },
  "peerDependencies": {
    "react": ">=18.2 <20",
    "react-dom": ">=18.2 <20"
  },
  "devDependencies": {
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "emf-converter": "1.5.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/extend-hq/react-pptx.git",
    "directory": "packages/react-viewer"
  },
  "bugs": {
    "url": "https://github.com/extend-hq/react-pptx/issues"
  },
  "homepage": "https://github.com/extend-hq/react-pptx#readme",
  "license": "MIT"
}
